@model SlothSecIpCheckerWeb.Models.AbuseIpReport

<h1>🦥 SlothSec IP Checker</h1>

<form method="post" asp-action="CheckIp">
    <input type="text" name="ip" placeholder="Enter IP Address" />
    <button type="submit">Check IP</button>
</form>

@if (Model?.data?.ipAddress != null && Model.data.ipAddress != "")
{
    <h2>Results for @Model.data.ipAddress</h2>
    <p>Risk Score: @Model.data.abuseConfidenceScore</p>
    <p>ISP: @Model.data.isp</p>
    <p>Domain: @Model.data.domain</p>
    <p>Country: @Model.data.countryCode</p>
}

